# ============================================================================
# CIVIC CROWDSOURCING PLATFORM — ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in every value.
# WhatsApp is optional; set DISABLE_WHATSAPP=true to skip it for pilot.
# ============================================================================

# ============================================================================
# 1. SUPABASE (Database + Auth + Storage + Edge Functions)
# ============================================================================
# Go to: https://app.supabase.com → Your Project → Settings → API
#   - Project URL:        copy from "Project URL" field
#   - Anon Key:           copy from "anon public" key (safe for client-side)
#   - Service Role Key:   copy from "service_role" key (SECRET — server/edge only)
#   - Also enable:        PostGIS extension from SQL Editor (CREATE EXTENSION postgis)
#   - Also create:        Storage buckets named "issue-photos" and "complaints"
#   - Also configure:     Database Webhooks to call Edge Functions on ratings INSERT

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# 2. CLAUDE API (Anthropic — Photo Moderation, Translation, PDF Generation)
# ============================================================================
# Go to: https://console.anthropic.com → API Keys → Create Key
#   - Model used: claude-sonnet-4-20250514
#   - Pricing:    ~$3/M input tokens, ~$15/M output tokens
#   - Rate limit: ~50 requests/min on Tier 1
#   - The API key always starts with "sk-ant-"

CLAUDE_API_KEY=sk-ant-api03-your-claude-api-key-here

# ============================================================================
# 3. GOOGLE MAPS (GPS Pinning, Static Maps, Geocoding)
# ============================================================================
# Go to: https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
#   - Enable these APIs on the key:
#       * Maps JavaScript API       (interactive map picker + cluster view)
#       * Maps Static API           (mini map thumbnails on issue detail pages)
#       * Geocoding API             (reverse-geocode GPS coords to ward/address)
#   - Billing:  Maps API requires a billing account. You get $200/month free credit.
#   - Restrict: Restrict the key to your domain(s) and the above 3 APIs only.
#   - IMPORTANT: This key is prefixed NEXT_PUBLIC_ and will be exposed in the browser.

NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...your-google-maps-api-key

# ============================================================================
# 4. TWILIO (OTP + SMS for Auth and Neighbor Notifications)
# ============================================================================
# Go to: https://console.twilio.com → Account → API Keys & Tokens
#   - Account SID:    starts with "AC" — found on dashboard
#   - Auth Token:     shown once when you create it — save immediately
#   - Phone Number:   buy a number from Twilio with SMS capability
#                     Format: +1XXXXXXXXXX (E.164)
#   - Verify Service: set up Verify v2 in Twilio Console for OTP auth
#   - Cost:           ~$0.0079/SMS in India, $0.05/OTP verification

TWILIO_ACCOUNT_SID=AC...your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ============================================================================
# 5. RESEND (Email — Formal Complaint PDF Delivery to Officials)
# ============================================================================
# Go to: https://resend.com → API Keys → Create Key
#   - Domain:   Verify your sending domain in Resend (e.g., mail.civic.app)
#   - From:     The verified "from" address used in threshold trigger emails
#   - Rate:     100 emails/day on free plan, 100+/sec on paid
#   - The API key starts with "re_"

RESEND_API_KEY=re_...your-resend-api-key

# ============================================================================
# 6. WHATSAPP BUSINESS API (Optional — Skip for Pilot)
# ============================================================================
# Set this to true to skip WhatsApp entirely. Officials get email + SMS only.
# No Meta Business verification needed. Perfect for pilot/testing.
DISABLE_WHATSAPP=true

# Only needed if DISABLE_WHATSAPP=false:
# Go to: https://developers.facebook.com → Create App → WhatsApp → Setup
#   - You need a Meta Business Account + verified phone number
#   - The token is a short-lived (24h) or long-lived (60d) access token
#   - Generate from: App Dashboard → WhatsApp → API Setup → Token
#   - Templates:     Pre-approve message templates:
#       "civic_complaint_notification"  (for officials when threshold met)
#       "nearby_issue_alert"            (for neighbor notifications)
#   - Phone Number ID: found in WhatsApp → API Setup → "Phone Number ID"

WHATSAPP_API_TOKEN=EAA...your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ============================================================================
# 7. PLATFORM (App URL — used in SMS/Email deep links)
# ============================================================================
# The production URL of your deployed Next.js app.
# Used to construct deep links like https://civic.app/issues/<id>
# in SMS and email notifications.

NEXT_PUBLIC_PLATFORM_URL=https://civic.app

# ============================================================================
# 8. OPTIONAL — Supabase Local Development (for testing)
# ============================================================================
# Install Supabase CLI:  npm install -g supabase
# Start local stack:     npx supabase start
# These are the defaults (port 54321 for API, 54322 for PG):

# SUPABASE_TEST_URL=http://127.0.0.1:54321
# SUPABASE_TEST_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMmYTn_I0
# SUPABASE_TEST_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM956RAZx9lJWRWYxVxfpnf8mBBOIG7KqT4DbypY4

# ============================================================================
# QUICK START — After filling .env.local:
# ============================================================================
# 1. npm install
# 2. npm run dev                     # Start Next.js
# 3. npx supabase start              # Start local Supabase (or use cloud)
# 4. psql < supabase/schema.sql     # Load schema + RLS + functions
# 5. psql < supabase/seed.sql       # Load test data (Hyderabad wards)
# 6. npx jest tests/threshold-trigger.test.ts  # Run tests
# ============================================================================
